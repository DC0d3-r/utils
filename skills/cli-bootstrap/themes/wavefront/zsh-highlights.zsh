# Theme: Wavefront — ZSH syntax highlighting
# Source this in your .zshrc after loading zsh-syntax-highlighting.

export ZSH_AUTOSUGGEST_HIGHLIGHT_STYLE="fg=#44445B"

typeset -A ZSH_HIGHLIGHT_STYLES
ZSH_HIGHLIGHT_STYLES[default]='fg=#DCD7BA'
ZSH_HIGHLIGHT_STYLES[unknown-token]='fg=#D0605A'
ZSH_HIGHLIGHT_STYLES[reserved-word]='fg=#957FB8'
ZSH_HIGHLIGHT_STYLES[alias]='fg=#7BA888'
ZSH_HIGHLIGHT_STYLES[builtin]='fg=#7BA888'
ZSH_HIGHLIGHT_STYLES[function]='fg=#7BA888'
ZSH_HIGHLIGHT_STYLES[command]='fg=#7BA888'
ZSH_HIGHLIGHT_STYLES[precommand]='fg=#7BA888,underline'
ZSH_HIGHLIGHT_STYLES[commandseparator]='fg=#957FB8'
ZSH_HIGHLIGHT_STYLES[path]='fg=#7E9CD8,underline'
ZSH_HIGHLIGHT_STYLES[globbing]='fg=#C4B28A'
ZSH_HIGHLIGHT_STYLES[single-quoted-argument]='fg=#6DB5A8'
ZSH_HIGHLIGHT_STYLES[double-quoted-argument]='fg=#6DB5A8'
ZSH_HIGHLIGHT_STYLES[dollar-quoted-argument]='fg=#6DB5A8'
ZSH_HIGHLIGHT_STYLES[back-quoted-argument]='fg=#957FB8'
ZSH_HIGHLIGHT_STYLES[assign]='fg=#C4B28A'
ZSH_HIGHLIGHT_STYLES[redirection]='fg=#C4B28A'
ZSH_HIGHLIGHT_STYLES[comment]='fg=#727169,italic'
ZSH_HIGHLIGHT_STYLES[arg0]='fg=#7BA888'
ZSH_HIGHLIGHT_STYLES[single-hyphen-option]='fg=#938E7E'
ZSH_HIGHLIGHT_STYLES[double-hyphen-option]='fg=#938E7E'
