# Theme: Neon Depths — ZSH syntax highlighting
# Source this in your .zshrc after loading zsh-syntax-highlighting.

export ZSH_AUTOSUGGEST_HIGHLIGHT_STYLE="fg=#3A3A4A"

typeset -A ZSH_HIGHLIGHT_STYLES
ZSH_HIGHLIGHT_STYLES[default]='fg=#D0CBE4'
ZSH_HIGHLIGHT_STYLES[unknown-token]='fg=#FF6B6B'
ZSH_HIGHLIGHT_STYLES[reserved-word]='fg=#BD93F9'
ZSH_HIGHLIGHT_STYLES[alias]='fg=#50FA7B'
ZSH_HIGHLIGHT_STYLES[builtin]='fg=#50FA7B'
ZSH_HIGHLIGHT_STYLES[function]='fg=#50FA7B'
ZSH_HIGHLIGHT_STYLES[command]='fg=#50FA7B'
ZSH_HIGHLIGHT_STYLES[precommand]='fg=#50FA7B,underline'
ZSH_HIGHLIGHT_STYLES[commandseparator]='fg=#BD93F9'
ZSH_HIGHLIGHT_STYLES[path]='fg=#6C99FF,underline'
ZSH_HIGHLIGHT_STYLES[globbing]='fg=#F1FA8C'
ZSH_HIGHLIGHT_STYLES[single-quoted-argument]='fg=#8BE9FD'
ZSH_HIGHLIGHT_STYLES[double-quoted-argument]='fg=#8BE9FD'
ZSH_HIGHLIGHT_STYLES[dollar-quoted-argument]='fg=#8BE9FD'
ZSH_HIGHLIGHT_STYLES[back-quoted-argument]='fg=#BD93F9'
ZSH_HIGHLIGHT_STYLES[assign]='fg=#F1FA8C'
ZSH_HIGHLIGHT_STYLES[redirection]='fg=#F1FA8C'
ZSH_HIGHLIGHT_STYLES[comment]='fg=#8080A0,italic'
ZSH_HIGHLIGHT_STYLES[arg0]='fg=#50FA7B'
ZSH_HIGHLIGHT_STYLES[single-hyphen-option]='fg=#9898B8'
ZSH_HIGHLIGHT_STYLES[double-hyphen-option]='fg=#9898B8'
